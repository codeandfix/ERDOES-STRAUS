-- VALIDIERUNG OHNE BEKANNTES n
#eval (fun x y z => 
  let numerator := 4 * x * y * z
  let denominator := (y * z + x * z + x * y)
  if numerator % denominator == 0 then
    let n := numerator / denominator
    s!"[TREFFER] n wurde rekonstruiert: {n}"
  else
    "Keine gültige Erdős-Strauss Lösung (n wäre keine Ganzzahl)"
)
